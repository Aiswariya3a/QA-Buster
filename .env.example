# ===== DATABASE CONFIGURATION =====
DATABASE_URL=sqlite:///./qa_buster.db

# ===== CSV INGESTION SETTINGS =====
# Replace with your actual Google Sheet export URL
# Format: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv
CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# Polling interval in seconds (how often to check for new questions)
INGEST_INTERVAL=5

# ===== LLM CONFIGURATION =====
# Local LM Studio server settings
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model

# LLM processing interval in seconds
LLM_WORKER_INTERVAL=10

# ===== FASTAPI SERVER SETTINGS =====
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Debug mode (set to False in production)
DEBUG=True

# ===== CORS SETTINGS =====
# Comma-separated list of allowed origins (use '*' for development only)
CORS_ORIGINS=*

# ===== LOGGING =====
LOG_LEVEL=INFO
